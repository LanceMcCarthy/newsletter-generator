{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build-debug",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "build",
        "newsletter-generator.slnx",
        "-c",
        "Debug"
      ],
      "group": "build",
      "problemMatcher": [
        "$msCompile"
      ]
    },
    {
      "label": "publish-release",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "publish",
        "src/NewsletterGenerator/NewsletterGenerator.csproj",
        "-c",
        "Release",
        "-o",
        "src/NewsletterGenerator/bin/Release/net10.0/publish"
      ],
      "group": "build",
      "problemMatcher": [
        "$msCompile"
      ]
    }
  ]
}
